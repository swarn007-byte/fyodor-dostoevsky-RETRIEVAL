datasource db {
  provider   = "postgresql"
  extensions = [vector] 
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"] 
}

// This is your blueprint for the table that will store your book chunks
model Document {
  id        BigInt   @id @default(autoincrement())
  content   String   
  metadata  Json    
  embedding Unsupported("vector(384)") 

  @@map("documents") 
}